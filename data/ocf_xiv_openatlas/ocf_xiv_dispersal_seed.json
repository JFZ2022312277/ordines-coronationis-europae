      {
        "id": "OCF-XIV",
        "label": "Ordo of Eleven Forms",
        "labelFr": "Ordo aux onze formules",
        "openatlasClass": "E33 Linguistic Object",
        "systemClass": "artifact",
        "viewClass": "artifact",
        "type": "ordo_text",
        "tradition": "OCF",
        "date": "900–50",
        "description": "A 10th-century ordo traditionally named after Stavelot or the 'seven forms.' Actually contains eleven formulas (seven for the king, four for the queen). The queen's formulas are nearly identical to Elze's Ordo III and were incorporated into the Romano-Germanic pontifical of Mainz and most later French ordines."
      }
    ],
