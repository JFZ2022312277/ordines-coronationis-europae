    "ordines": [
      {
        "id": "OCF-XXIIA",
        "label": "Last Capetian Ordo",
        "labelFr": "Dernier Ordo capétien",
        "openatlasClass": "E33 Linguistic Object",
        "systemClass": "artifact",
        "viewClass": "artifact",
        "type": "ordo_text",
        "tradition": "OCF",
        "date": "1250–270",
        "description": "The first complete ordo that is both specifically 'French' and usable at a coronation. Combines the Ratold Ordo and the Ordo of Reims. The most successful of all French coronation ordines: it supplied the ceremony's structure from the late 13th century to the coronation of John in 1350, then was modified for Charles V in 1364. Reused for Charles VII in 1429 and Louis XI in 1461. Its features remained in the ceremony until the end of the Old Regime."
      }
    ],
