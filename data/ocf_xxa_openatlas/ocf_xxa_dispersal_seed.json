      {
        "id": "OCF-XXA",
        "label": "Ordo of Reims",
        "labelFr": "Ordo de Reims",
        "openatlasClass": "E33 Linguistic Object",
        "systemClass": "artifact",
        "viewClass": "artifact",
        "type": "ordo_text",
        "tradition": "OCF",
        "date": "ca. 1230",
        "description": "Not a full ordo but a modus-it gives instructions for the ceremony while omitting liturgical texts, to be used with a pontifical. Extremely important as the first text providing for the Holy Ampulla, the peers of France, the oath to expel heretics, and investiture with ankle boots and spurs. Marks the transition to a specifically French coronation ritual."
      }
    ],
