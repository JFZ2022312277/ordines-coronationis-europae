    "ordines": [
      {
        "id": "OCF-XXIII",
        "label": "Ordo of Charles V",
        "labelFr": "Ordo de Charles V",
        "openatlasClass": "E33 Linguistic Object",
        "systemClass": "artifact",
        "viewClass": "artifact",
        "type": "ordo_text",
        "tradition": "OCF",
        "date": "19 May 1364",
        "description": "Unusual in many ways. Personally supervised by Charles V, who signed the manuscript. Famous, highly detailed miniatures-the best example of an illustrated coronation text from medieval France. The longest of all French ordines. Reflects current political circumstances: the English claim to the French throne, King John's death in England, heavy ransom and territorial losses. Contains 19 new formulas. Formed the core of coronations from 1364 through the livre rouge to the end of the Old Regime."
      }
    ],
