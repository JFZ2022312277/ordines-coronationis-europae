    "ordines": [
      {
        "id": "OCF-XXV",
        "label": "Ordo of Charles VIII",
        "labelFr": "Ordo de Charles VIII",
        "openatlasClass": "E33 Linguistic Object",
        "systemClass": "artifact",
        "viewClass": "artifact",
        "type": "ordo_text",
        "tradition": "OCF",
        "date": "29 May ”2 June 1484",
        "description": "Differs markedly from all previous texts. Not a generic ordo but a precise, full description of a specific event-unprecedented in the history of the ceremony. Contains the entire liturgy plus extensive descriptions of the king's entry into Reims, local detail, and records of active participants. Written by a cleric in the archbishop's entourage, probably the cathedral Dean. Primary liturgical source was the livre rouge. Set the standard for reporting future coronations. A fitting conclusion to the edition."
      }
    ],
